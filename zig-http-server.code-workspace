{
  "folders": [
    {
      "path": ".",
    },
  ],
  "settings": {
    "zig.zls.enabled": "on",
    "zig.zlint.enabled": true,
    "zig.path": "zig",
    "[zig]": {
      "editor.inlayHints.enabled": "off",
      "editor.tabSize": 4,
    },
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
    },
    "editor.semanticTokenColorCustomizations": {
      "rules": {
        "*.deprecated": {
          "strikethrough": true,
        },
      },
    },
  },
}
